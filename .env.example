# === Medienquellen (alle nur lesend) ===
# Quellen (Emby/Jellyfin/Plex/lokale Ordner) werden ab Phase 4a im UI unter
# Einstellungen -> Datenquellen angelegt und verschluesselt in der DB
# gespeichert - nicht mehr ueber Umgebungsvariablen.

# === Externe Metadaten ===
# themoviedb.org -> Einstellungen -> API (v3). Für FSK-Vorschläge,
# Genres und Vollständigkeitsprüfung. Leer = diese Funktionen aus.
TMDB_API_KEY=

# === Automatik & Benachrichtigung ===
# Hintergrund-Scan alle N Stunden (0 = aus).
SCAN_INTERVAL_HOURS=0
# Generischer JSON-Webhook (Discord/ntfy/Apprise). Leer = aus.
NOTIFY_WEBHOOK_URL=

# === Ausnahme: aktives Zurückschreiben nach Emby (FSK) ===
# Standard 0 (read-only). Nur auf 1 setzen, wenn SelfMediaHub die
# FSK-Freigabe aktiv in Emby setzen darf.
ALLOW_EMBY_WRITE=0

# === App ===
PORT=8092
DATA_DIR=./data
