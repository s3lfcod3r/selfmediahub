# --- Medienquelle (nur lesend) ---
# Adresse deines Emby-Servers, ohne Slash am Ende.
EMBY_URL=http://192.168.1.19:8096
# Emby: Einstellungen -> Erweitert -> API-Schluessel.
EMBY_API_KEY=dein_emby_api_key

# --- Optional (erst ab Phase 2: Metadaten-Abgleich) ---
# themoviedb.org -> Einstellungen -> API (v3). Leer = deaktiviert.
TMDB_API_KEY=

# --- App ---
# Port der Weboberflaeche.
PORT=8092
# Ablageort der eigenen Datenbank (lokal z.B. ./data setzen).
DATA_DIR=./data
