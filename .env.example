# === Medienquellen (alle nur lesend) ===
# Mindestens eine Quelle konfigurieren.

# --- Emby ---
EMBY_URL=http://192.168.1.19:8096
EMBY_API_KEY=dein_emby_api_key

# --- Jellyfin (optional) ---
JELLYFIN_URL=
JELLYFIN_API_KEY=

# --- Plex (optional) ---
PLEX_URL=
PLEX_TOKEN=

# --- Lokale Ordner (optional, Komma-getrennt) ---
LOCAL_PATHS=

# === Externe Metadaten ===
# themoviedb.org -> Einstellungen -> API (v3). Fuer FSK-Vorschlaege,
# Genres und Vollstaendigkeitspruefung. Leer = diese Funktionen aus.
TMDB_API_KEY=

# === Automatik & Benachrichtigung ===
# Hintergrund-Scan alle N Stunden (0 = aus).
SCAN_INTERVAL_HOURS=0
# Generischer JSON-Webhook (Discord/ntfy/Apprise). Leer = aus.
NOTIFY_WEBHOOK_URL=

# === Ausnahme: aktives Zurueckschreiben nach Emby (FSK) ===
# Standard 0 (read-only). Nur auf 1 setzen, wenn SelfMediaHub die
# FSK-Freigabe aktiv in Emby setzen darf.
ALLOW_EMBY_WRITE=0

# === App ===
PORT=8092
DATA_DIR=./data
