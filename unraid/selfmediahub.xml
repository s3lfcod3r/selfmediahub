<?xml version="1.0"?>
<Container version="2">
  <Name>SelfMediaHub</Name>
  <Repository>ghcr.io/s3lfcod3r/selfmediahub:latest</Repository>
  <Registry>https://github.com/s3lfcod3r/selfmediahub/pkgs/container/selfmediahub</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/s3lfcod3r/selfmediahub/issues</Support>
  <Project>https://github.com/s3lfcod3r/selfmediahub</Project>
  <Overview>Read-only Analyse- und Übersichtsschicht für bestehende Mediatheken (Emby; Plex/Jellyfin/lokal folgen). Liest Filme und Serien nur lesend ein und speichert alles in einer eigenen Datenbank - es wird nie in den Medienserver zurückgeschrieben. Cover- und frei konfigurierbare Listenansicht, Filter nach Bibliothek, Typ und Freigabe. Weitere Phasen: Technik-/Qualitätsanalyse, Vollständigkeitsprüfung, Tags und Regeln, Benachrichtigungen.</Overview>
  <Category>MediaApp:Video Tools: Productivity:</Category>
  <WebUI>http://[IP]:[PORT:8092]/</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/s3lfcod3r/selfmediahub/main/icon.png</Icon>
  <Config Name="WebUI Port" Target="8092" Default="8092" Mode="tcp" Description="Port der Weboberfläche" Type="Port" Display="always" Required="true" Mask="false">8092</Config>
  <Config Name="Daten (DB)" Target="/data" Default="/mnt/user/appdata/selfmediahub" Mode="rw" Description="Ablage der eigenen Datenbank" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/selfmediahub</Config>
  <!-- Datenquellen (Emby/Jellyfin/Plex/lokale Ordner) werden im UI unter
       Einstellungen -> Datenquellen angelegt und verschluesselt in der DB
       gespeichert - nicht mehr ueber Umgebungsvariablen. -->
  <Config Name="TMDb API Key (optional)" Target="TMDB_API_KEY" Default="" Description="themoviedb.org v3-Key. Für FSK-Vorschläge, Genres und Vollständigkeit." Type="Variable" Display="always" Required="false" Mask="true"></Config>
  <Config Name="Scan-Intervall Stunden" Target="SCAN_INTERVAL_HOURS" Default="0" Description="Hintergrund-Scan alle N Stunden (0 = aus)" Type="Variable" Display="advanced" Required="false" Mask="false">0</Config>
  <Config Name="Benachrichtigungs-Webhook" Target="NOTIFY_WEBHOOK_URL" Default="" Description="Generischer JSON-Webhook (Discord/ntfy/Apprise). Leer = aus." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="Emby-Schreiben erlauben (FSK)" Target="ALLOW_EMBY_WRITE" Default="0" Description="1 = FSK aktiv nach Emby zurückschreiben. Standard 0 (read-only)." Type="Variable" Display="advanced" Required="false" Mask="false">0</Config>
</Container>
